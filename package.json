{
  "name": "@giki/admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3112",
    "build": "next build",
    "start": "next start",
    "deploy": "DEPLOY_ID=$(git rev-parse --short HEAD) && NEXT_PUBLIC_DEPLOY_ID=$DEPLOY_ID npx opennextjs-cloudflare build && wrangler deploy --var DEPLOY_ID:$DEPLOY_ID",
    "lint": "pnpm exec biome lint .",
    "format": "pnpm exec biome format --write .",
    "format:check": "pnpm exec biome format .",
    "check": "pnpm exec biome check .",
    "check:fix": "pnpm exec biome check --write .",
    "test": "jest --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gikiuk/facts-engine": "^0.9.0",
    "@sentry/nextjs": "^10",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-virtual": "^3.13.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-sankey": "^0.12.3",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "logic-solver": "^2.0.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "3.8.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
